<Window x:Class="ChatApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ChatApp"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row = "0" Margin="0,0,0,10">
            <TextBox x:Name="txtUsername" Width="100" Margin="0,0,5,0" Tag="Nickname"/>
            <Button x:Name="btnConnect" Content="Kết nối" Click="BtnConnect_Click" Width="80"/>
        </StackPanel>

        <ListBox x:Name="lstChat" Grid.Row="1" Margin="0,0,0,10"/>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" Grid.Row="2">
                <TextBox x:Name="txtMessage" Width="250" Margin="0,0,5,0" KeyDown="TxtMessage_KeyDown"/>

                <Button x:Name="btnEmoji" Content="😊" Width="30" Margin="0,0,5,0" Click="BtnEmoji_Click"/>

                <Button x:Name="btnSend" Content="Gửi" Width="60" Click="BtnSend_Click"/>
            </StackPanel>

            <Popup x:Name="popEmoji" PlacementTarget="{Binding ElementName=btnEmoji}" StaysOpen="False">
                <Border Background="White" BorderBrush="Gray" BorderThickness="1" CornerRadius="5">
                    <WrapPanel Width="150" Margin="5">
                        <Button Content="😀" Click="AddEmoji_Click" Margin="2" Padding="5"/>
                        <Button Content="😂" Click="AddEmoji_Click" Margin="2" Padding="5"/>
                        <Button Content="😍" Click="AddEmoji_Click" Margin="2" Padding="5"/>
                        <Button Content="👍" Click="AddEmoji_Click" Margin="2" Padding="5"/>
                        <Button Content="🔥" Click="AddEmoji_Click" Margin="2" Padding="5"/>
                        <Button Content="🎉" Click="AddEmoji_Click" Margin="2" Padding="5"/>
                    </WrapPanel>
                </Border>
            </Popup>
        </Grid>
    </Grid>
</Window>
