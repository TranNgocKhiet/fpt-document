<Window x:Class="ChatApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf" 
        xmlns:local="clr-namespace:ChatApp"
        Title="Modern Chat" Height="700" Width="1000" WindowStartupLocation="CenterScreen"
        Background="#F5F7FB">

    <Window.Resources>
        <ResourceDictionary>
            <local:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />

            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

            <SolidColorBrush x:Key="WindowBgBrush" Color="#F5F7FB" />
            <SolidColorBrush x:Key="IconBrush" Color="#4F46E5" />
            <SolidColorBrush x:Key="InputBarBrush" Color="#FFFFFF" />
            <SolidColorBrush x:Key="BorderBrush" Color="#EEEEEE" />

            <Style x:Key="IconButton" TargetType="Button">
                <Setter Property="Foreground" Value="{DynamicResource IconBrush}"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Width" Value="45"/>
                <Setter Property="Height" Value="45"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" CornerRadius="22" Background="{TemplateBinding Background}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#20888888"/>
                                    <Setter Property="RenderTransform">
                                        <Setter.Value>
                                            <ScaleTransform ScaleX="1.1" ScaleY="1.1"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="EmojiButtonStyle" TargetType="Button" BasedOn="{StaticResource IconButton}">
                <Setter Property="Width" Value="50"/>
                <Setter Property="Height" Value="50"/>
                <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            </Style>

        </ResourceDictionary>
    </Window.Resources>

    <Grid Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}">
    <Border Background="{DynamicResource WindowBgBrush}">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <RowDefinition Height="*"/>    <RowDefinition Height="Auto"/> </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,15">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <Border Background="White" CornerRadius="15" Padding="15,5">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="User:" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="#6B7280"/>
                            <TextBox x:Name="txtUsername" Width="150" BorderThickness="0" VerticalContentAlignment="Center" FontSize="16"/>
                            <Button x:Name="btnConnect" Content="Connect" Click="BtnConnect_Click" Margin="10,0,0,0" Padding="15,5" Background="#4F46E5" Foreground="White">
                                <Button.Resources>
                                    <Style TargetType="Border"><Setter Property="CornerRadius" Value="10"/></Style>
                                </Button.Resources>
                            </Button>
                        </StackPanel>
                    </Border>
                </StackPanel>
                
                <Button HorizontalAlignment="Right" Width="40" Height="40" Click="ToggleDarkMode_Click" Style="{StaticResource IconButton}">
                    <TextBlock Text="🌙" FontSize="20"/>
                </Button>
            </Grid>

                <ListBox x:Name="lstChat" Grid.Row="1" Margin="0,0,0,15" 
                     HorizontalContentAlignment="Stretch" BorderThickness="0" Background="Transparent"
                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,5">
                                <StackPanel HorizontalAlignment="{Binding Alignment}" MaxWidth="700">
                                    <TextBlock Text="{Binding Sender}" FontSize="11" Foreground="#9CA3AF" 
                           Margin="12,0,12,2" HorizontalAlignment="{Binding Alignment}"/>

                                    <StackPanel>
                                        <Border Background="{Binding BubbleColor}" CornerRadius="18" Padding="15,10" 
                            MouseDown="OnMessageMouseDown" BorderThickness="1" BorderBrush="#05000000"
                            Visibility="{Binding Message, Converter={StaticResource StringToVisibilityConverter}}">
                                            <StackPanel>
                                                <emoji:TextBlock Text="{Binding Message}" FontSize="16" TextWrapping="Wrap" Foreground="#1F2937"/>

                                                <Grid Visibility="{Binding IsTransferring, Converter={StaticResource BooleanToVisibilityConverter}}" Margin="0,8,0,0">
                                                    <ProgressBar Value="{Binding Progress}" Height="4" Minimum="0" Maximum="100" Foreground="#4F46E5"/>
                                                </Grid>
                                            </StackPanel>
                                        </Border>

                                        <Border CornerRadius="10" ClipToBounds="True" Margin="0,5"
                            Visibility="{Binding HasImage, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <Image Source="{Binding ImageData}" MaxWidth="400" MaxHeight="300" Stretch="Uniform"/>
                                        </Border>

                                        <TextBlock Text="{Binding Time}" FontSize="10" Foreground="#9CA3AF" 
                               HorizontalAlignment="{Binding Alignment}" Margin="5,2,5,0"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Border Grid.Row="2" Background="White" CornerRadius="25" Padding="10,5" Margin="0,10,0,0" BorderBrush="#EEE" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button x:Name="btnFile" Grid.Column="0" Content="📎" FontSize="22" Style="{StaticResource IconButton}" Click="BtnSendFile_Click" IsEnabled="False"/>
                    <Button x:Name="btnEmoji" Grid.Column="1" Content="😊" FontSize="22" Style="{StaticResource IconButton}" Click="BtnEmoji_Click" IsEnabled="False"/>

                    <emoji:TextBox x:Name="txtMessage" Grid.Column="3" BorderThickness="0" Background="Transparent" FontSize="30" VerticalContentAlignment="Center" Padding="10" KeyDown="TxtMessage_KeyDown" IsEnabled="False"/>

                    <Button x:Name="btnSend" Grid.Column="4" Content="➤" FontSize="20" Width="50" Height="50" Style="{StaticResource IconButton}" Background="#4F46E5" Foreground="White" Click="BtnSend_Click" IsEnabled="False"/>

                    <Popup x:Name="popEmoji" PlacementTarget="{Binding ElementName=btnEmoji}" StaysOpen="False" Placement="Top" VerticalOffset="-10">
                        <Border Background="White" CornerRadius="15" Padding="10" BorderBrush="#DDD" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="Emojis" FontWeight="Bold" Margin="5,0,0,5" Foreground="Gray"/>
                                <WrapPanel Width="280">
                                    <Button Click="AddEmoji_Click" Style="{StaticResource EmojiButtonStyle}"><emoji:TextBlock Text="😀" FontSize="25"/></Button>
                                    <Button Click="AddEmoji_Click" Style="{StaticResource EmojiButtonStyle}"><emoji:TextBlock Text="😂" FontSize="25"/></Button>
                                    <Button Click="AddEmoji_Click" Style="{StaticResource EmojiButtonStyle}"><emoji:TextBlock Text="🤣" FontSize="25"/></Button>
                                    <Button Click="AddEmoji_Click" Style="{StaticResource EmojiButtonStyle}"><emoji:TextBlock Text="😍" FontSize="25"/></Button>
                                    <Button Click="AddEmoji_Click" Style="{StaticResource EmojiButtonStyle}"><emoji:TextBlock Text="😎" FontSize="25"/></Button>
                                    <Button Click="AddEmoji_Click" Style="{StaticResource EmojiButtonStyle}"><emoji:TextBlock Text="🥳" FontSize="25"/></Button>
                                    <Button Click="AddEmoji_Click" Style="{StaticResource EmojiButtonStyle}"><emoji:TextBlock Text="👍" FontSize="25"/></Button>
                                    <Button Click="AddEmoji_Click" Style="{StaticResource EmojiButtonStyle}"><emoji:TextBlock Text="❤️" FontSize="25"/></Button>
                                    <Button Click="AddEmoji_Click" Style="{StaticResource EmojiButtonStyle}"><emoji:TextBlock Text="🔥" FontSize="25"/></Button>
                                    <Button Click="AddEmoji_Click" Style="{StaticResource EmojiButtonStyle}"><emoji:TextBlock Text="✨" FontSize="25"/></Button>
                                    <Button Click="AddEmoji_Click" Style="{StaticResource EmojiButtonStyle}"><emoji:TextBlock Text="🎉" FontSize="25"/></Button>
                                    <Button Click="AddEmoji_Click" Style="{StaticResource EmojiButtonStyle}"><emoji:TextBlock Text="🎁" FontSize="25"/></Button>
                                    <Button Click="AddEmoji_Click" Style="{StaticResource EmojiButtonStyle}"><emoji:TextBlock Text="🤔" FontSize="25"/></Button>
                                    <Button Click="AddEmoji_Click" Style="{StaticResource EmojiButtonStyle}"><emoji:TextBlock Text="😱" FontSize="25"/></Button>
                                    <Button Click="AddEmoji_Click" Style="{StaticResource EmojiButtonStyle}"><emoji:TextBlock Text="🚀" FontSize="25"/></Button>
                                    <Button Click="AddEmoji_Click" Style="{StaticResource EmojiButtonStyle}"><emoji:TextBlock Text="💻" FontSize="25"/></Button>
                                </WrapPanel>
                            </StackPanel>
                        </Border>
                    </Popup>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Grid>
</Window>