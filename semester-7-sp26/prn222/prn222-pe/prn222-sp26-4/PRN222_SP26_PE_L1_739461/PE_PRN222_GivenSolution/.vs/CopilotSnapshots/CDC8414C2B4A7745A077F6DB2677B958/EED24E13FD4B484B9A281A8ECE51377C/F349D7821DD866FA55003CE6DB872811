@model IEnumerable<Q2.Models.Customer>
@{
    var selectedName = ViewBag.SelectedCustomerName as string;
    var selectedCity = ViewBag.SelectedCity as string;
    var cities = ViewBag.Cities as List<string> ?? new List<string>();
    var customerOrders = ViewBag.CustomerOrders as List<Q2.Models.Order> ?? new List<Q2.Models.Order>();
}
<h2>Customer List</h2>
<div>
    <a href="/Customer/Create">Add New Customer</a>
</div>
<form method="get" action="/Customer/List">
    <select id="sl_city" name="city">
        <option id="opt_default" value="">All Cities</option>
        @for (int i = 0; i < cities.Count; i++)
        {
            <option id="opt_@(i + 1)" value="@cities[i]" selected="@(selectedCity == cities[i])">@cities[i]</option>
        }
    </select>

    <button type="submit" id="btn_filter">Filter</button>
</form>
<table class="table">
    <thead>
        <tr>
            <th>CustomerId</th>
            <th>CustomerName</th>
            <th>Email</th>
            <th>City</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var customer in Model)
        {
            <tr>
                <td id="td_customerId_@customer.CustomerId">@customer.CustomerId</td>
                <td id="td_customerName_@customer.CustomerName">
                    <a id="a_@customer.CustomerName" href="@Url.Action("List", "Customer", new { customerName = customer.CustomerName })">@customer.CustomerName</a>
                </td>
                <td id="td_email_@customer.Email">@customer.Email</td>
                <td id="td_city_@customer.City">@customer.City</td>
            </tr>
        }
    </tbody>
</table>

@if (!string.IsNullOrWhiteSpace(selectedName))
{
    <h3>Orders of @selectedName</h3>
    <table class="table">
        <thead>
            <tr>
                <th>OrderId</th>
                <th>OrderDate</th>
                <th>TotalAmount</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var order in customerOrders)
            {
                <tr>
                    <td>@order.OrderId</td>
                    <td>@order.OrderDate</td>
                    <td>@order.TotalAmount</td>
                    <td>@order.Status</td>
                </tr>
            }
        </tbody>
    </table>
}
