@model IEnumerable<Q2.Models.Customer>
@{
    var selectedName = ViewBag.SelectedCustomerName as string;
    var selectedCity = ViewBag.SelectedCity as string;
    var cities = ViewBag.Cities as List<string> ?? new List<string>();
    var customerOrders = ViewBag.CustomerOrders as List<Q2.Models.Order> ?? new List<Q2.Models.Order>();
    var orderCount = (int?)ViewBag.OrderCount ?? 0;
    var totalAmount = (decimal?)ViewBag.TotalAmount ?? 0;
}
<h2>Customer List</h2>
<div>
    <a id="lnk_addNew" href="/Customer/Create">Add New Customer</a>
</div>
<form method="get" action="/Customer/List">
    <select id="sl_city" name="city">
        <option id="opt_default" value="" selected="@(string.IsNullOrWhiteSpace(selectedCity))">All Cities</option>
        @for (int i = 0; i < cities.Count; i++)
        {
            <option id="opt_@(i + 1)" value="@cities[i]" selected="@(selectedCity == cities[i])">@cities[i]</option>
        }
    </select>

    <button type="submit" id="btn_filter">Filter</button>
</form>
<table class="table">
    <thead>
        <tr>
            <th>CustomerId</th>
            <th>CustomerName</th>
            <th>Email</th>
            <th>City</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var customer in Model)
        {
            <tr>
                <td id="td_customerId_@customer.CustomerId">@customer.CustomerId</td>
                <td id="td_customerName_@customer.CustomerId">
                    <a id="a_@customer.CustomerId" href="/Customer/List/@customer.CustomerName">@customer.CustomerName</a>
                </td>
                <td id="td_email_@customer.CustomerId">@customer.Email</td>
                <td id="td_city_@customer.CustomerId">@customer.City</td>
            </tr>
        }
    </tbody>
</table>

@if (!string.IsNullOrWhiteSpace(selectedName))
{
    <h3>Orders</h3>
    <div>
        Order Count: <span id="span_orderCount">@orderCount</span>
        | Total Amount: <span id="span_totalAmount">@totalAmount.ToString("0.00")</span>
    </div>
    <table class="table">
        <thead>
            <tr>
                <th>OrderId</th>
                <th>OrderDate</th>
                <th>TotalAmount</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var order in customerOrders)
            {
                <tr>
                    <td id="td_orderId_@order.OrderId">@order.OrderId</td>
                    <td id="td_orderDate_@order.OrderId">@order.OrderDate</td>
                    <td id="td_totalAmount_@order.OrderId">@order.TotalAmount.ToString("0.00")</td>
                    <td id="td_status_@order.OrderId">@order.Status</td>
                </tr>
            }
        </tbody>
    </table>
}
